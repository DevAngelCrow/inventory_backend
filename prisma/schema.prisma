generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model ctl_category_permissions {
  name            String            @unique @db.VarChar(255)
  description     String            @db.VarChar(255)
  created_at      DateTime?         @db.Timestamp(0)
  updated_at      DateTime?         @db.Timestamp(0)
  deleted_at      DateTime?         @db.Timestamp(0)
  active          Boolean           @default(true)
  id              String            @id @default(uuid()) @db.Uuid
  ctl_permissions ctl_permissions[]
}

model ctl_country {
  name                         String                         @unique @db.VarChar(150)
  iso2                         String                         @db.VarChar(2)
  abbreviation                 String                         @db.VarChar(150)
  code                         String                         @db.VarChar(150)
  phone_code                   String                         @db.VarChar(150)
  active                       Boolean                        @default(true)
  created_at                   DateTime?                      @db.Timestamp(0)
  updated_at                   DateTime?                      @db.Timestamp(0)
  deleted_at                   DateTime?                      @db.Timestamp(0)
  id                           String                         @id @default(uuid()) @db.Uuid
  ctl_geographic_division      ctl_geographic_division[]
  ctl_geographic_division_type ctl_geographic_division_type[]
  people_country               people_country[]
}

model ctl_document_type {
  name         String         @unique @db.VarChar(150)
  description  String         @db.VarChar(150)
  mask         String         @db.VarChar(150)
  active       Boolean        @default(true)
  created_at   DateTime?      @db.Timestamp(0)
  updated_at   DateTime?      @db.Timestamp(0)
  deleted_at   DateTime?      @db.Timestamp(0)
  id           String         @id @default(uuid()) @db.Uuid
  mnt_document mnt_document[]
}

model ctl_gender {
  name       String       @unique @db.VarChar(100)
  created_at DateTime?    @db.Timestamp(0)
  updated_at DateTime?    @db.Timestamp(0)
  deleted_at DateTime?    @db.Timestamp(0)
  id         String       @id @default(uuid()) @db.Uuid
  mnt_people mnt_people[]
}

model ctl_marital_status {
  name        String       @unique @db.VarChar(100)
  description String       @db.VarChar(255)
  created_at  DateTime?    @db.Timestamp(0)
  updated_at  DateTime?    @db.Timestamp(0)
  deleted_at  DateTime?    @db.Timestamp(0)
  id          String       @id @default(uuid()) @db.Uuid
  mnt_people  mnt_people[]
}

model ctl_permissions {
  name                     String                   @unique(map: "ctl_permissions_name_unique") @db.VarChar(150)
  description              String                   @db.VarChar(150)
  created_at               DateTime?                @db.Timestamp(0)
  updated_at               DateTime?                @db.Timestamp(0)
  deleted_at               DateTime?                @db.Timestamp(0)
  active                   Boolean                  @default(true)
  id                       String                   @id @default(uuid()) @db.Uuid
  id_category_permissions  String                   @db.Uuid
  ctl_category_permissions ctl_category_permissions @relation(fields: [id_category_permissions], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ctl_permissions_id_category_permissions_foreign")
  mnt_route_permissions    mnt_route_permissions[]
  rol_permissions          rol_permissions[]

  @@unique([name, id_category_permissions], name: "ctl_permissions_name_id_category_permissions_unique")
  @@index([id_category_permissions])
}

model ctl_provider_storage {
  name              String              @unique @db.VarChar(150)
  code              String              @db.VarChar(6)
  description       String              @db.VarChar(150)
  active            Boolean             @default(true)
  deleted_at        DateTime?           @db.Timestamp(0)
  created_at        DateTime?           @db.Timestamp(0)
  updated_at        DateTime?           @db.Timestamp(0)
  id                String              @id @default(uuid()) @db.Uuid
  mnt_storage_files mnt_storage_files[]
}

model ctl_status {
  code                String              @db.VarChar(255)
  name                String              @db.VarChar(255)
  description         String              @db.VarChar(255)
  active              Boolean             @default(true)
  deleted_at          DateTime?           @db.Timestamp(0)
  created_at          DateTime?           @db.Timestamp(0)
  updated_at          DateTime?           @db.Timestamp(0)
  state_color         String              @default("#9b9b9b") @db.VarChar(10)
  text_color          String              @default("#FFFFFF") @db.VarChar(10)
  id                  String              @id @default(uuid()) @db.Uuid
  id_category_status  String              @db.Uuid
  ctl_category_status ctl_category_status @relation(fields: [id_category_status], references: [id], onDelete: Cascade, map: "ctl_status_ctl_category_status_fk")
  mnt_people          mnt_people[]
  mnt_role            mnt_role[]
  mnt_user            mnt_user[]

  @@unique([code, id_category_status], map: "ctl_status_code_category_unique")
  @@index([id_category_status])
  @@index([code])
}

model mnt_address {
  street                  String                   @db.VarChar(150)
  street_number           String                   @db.VarChar(150)
  neighborhood            String                   @db.VarChar(150)
  house_number            String                   @db.VarChar(150)
  block                   String                   @db.VarChar(150)
  pathway                 String                   @db.VarChar(150)
  current                 Boolean
  created_at              DateTime?                @db.Timestamp(0)
  updated_at              DateTime?                @db.Timestamp(0)
  deleted_at              DateTime?                @db.Timestamp(0)
  active                  Boolean                  @default(true)
  id                      String                   @id @default(uuid()) @db.Uuid
  id_people               String                   @db.Uuid
  id_geographic_division  String?                  @db.Uuid
  ctl_geographic_division ctl_geographic_division? @relation(fields: [id_geographic_division], references: [id], onDelete: Cascade, map: "mnt_address_ctl_geographic_division_fk")
  mnt_people              mnt_people               @relation(fields: [id_people], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_address_id_people_foreign")

  @@index([id_people])
  @@index([id_geographic_division])
  @@index([id_people, current])
}

model mnt_document {
  document_number   String            @unique @db.VarChar(255)
  description       String?           @db.VarChar(150)
  active            Boolean           @default(true)
  created_at        DateTime?         @db.Timestamp(0)
  updated_at        DateTime?         @db.Timestamp(0)
  deleted_at        DateTime?         @db.Timestamp(0)
  id                String            @id @default(uuid()) @db.Uuid
  id_document_type  String            @db.Uuid
  id_people         String            @db.Uuid
  ctl_document_type ctl_document_type @relation(fields: [id_document_type], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_document_id_document_type_foreign")
  mnt_people        mnt_people        @relation(fields: [id_people], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_document_id_people_foreign")

  @@index([id_document_type])
  @@index([id_people])
}

model mnt_people {
  first_name         String?            @db.VarChar(150)
  middle_name        String?            @db.VarChar(150)
  last_name          String?            @db.VarChar(150)
  birthdate          DateTime?          @db.Date
  email              String             @unique(map: "mnt_people_email_unique") @db.VarChar(150)
  img_path           String?            @db.VarChar(255)
  phone              String?            @db.VarChar(14)
  created_at         DateTime?          @db.Timestamp(0)
  updated_at         DateTime?          @db.Timestamp(0)
  deleted_at         DateTime?          @db.Timestamp(0)
  id                 String             @id @default(uuid()) @db.Uuid
  id_gender          String?            @db.Uuid
  id_marital_status  String?            @db.Uuid
  id_status          String             @db.Uuid
  mnt_address        mnt_address[]
  mnt_document       mnt_document[]
  ctl_gender         ctl_gender?        @relation(fields: [id_gender], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_people_id_gender_foreign")
  ctl_marital_status ctl_marital_status? @relation(fields: [id_marital_status], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_people_id_marital_status_foreign")
  ctl_status         ctl_status         @relation(fields: [id_status], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_people_id_status_foreign")
  mnt_user           mnt_user?
  people_country     people_country[]

  @@index([id_status])
  @@index([id_gender])
  @@index([id_marital_status])
  @@index([deleted_at])
}

model mnt_role {
  name            String            @db.VarChar(150)
  description     String            @db.VarChar(150)
  created_at      DateTime?         @db.Timestamp(0)
  updated_at      DateTime?         @db.Timestamp(0)
  deleted_at      DateTime?         @db.Timestamp(0)
  active          Boolean           @default(true)
  code            String            @unique(map: "mnt_role_unique") @db.VarChar(15)
  id              String            @id @default(uuid()) @db.Uuid
  id_status       String            @db.Uuid
  ctl_status      ctl_status        @relation(fields: [id_status], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_role_id_status_foreign")
  mnt_user_rol    mnt_user_rol[]
  rol_permissions rol_permissions[]

  @@index([id_status])
}

model mnt_route {
  name                  String                  @db.VarChar(150)
  description           String?                 @db.VarChar(255)
  icon                  String                  @db.VarChar(150)
  uri                   String                  @db.VarChar(150)
  active                Boolean                 @default(true)
  show                  Boolean                 @default(true)
  order                 Int?
  required_auth         Boolean                 @default(true)
  title                 String                  @db.VarChar(150)
  created_at            DateTime?               @db.Timestamp(0)
  updated_at            DateTime?               @db.Timestamp(0)
  deleted_at            DateTime?               @db.Timestamp(0)
  id                    String                  @id @default(uuid()) @db.Uuid
  id_parent             String?                 @db.Uuid
  parent                mnt_route?              @relation("mnt_routeTomnt_route", fields: [id_parent], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_route_id_parent_foreign")
  children              mnt_route[]             @relation("mnt_routeTomnt_route")
  mnt_route_permissions mnt_route_permissions[]

  @@index([id_parent])
  @@index([active, show, order])
}

model mnt_route_permissions {
  created_at      DateTime?       @db.Timestamp(0)
  updated_at      DateTime?       @db.Timestamp(0)
  deleted_at      DateTime?       @db.Timestamp(0)
  id              String          @id @default(uuid()) @db.Uuid
  id_permission   String          @db.Uuid
  id_route        String          @db.Uuid
  ctl_permissions ctl_permissions @relation(fields: [id_permission], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_route_permissions_id_permission_foreign")
  mnt_route       mnt_route       @relation(fields: [id_route], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_route_permissions_id_route_foreign")

  @@unique([id_route, id_permission], map: "mnt_route_permissions_route_permission_unique")
  @@index([id_route])
  @@index([id_permission])
}

model mnt_storage_files {
  filename             String               @db.VarChar(150)
  path                 String               @db.VarChar(500)
  size                 BigInt
  mime_type            String               @db.VarChar(150)
  active               Boolean              @default(true)
  deleted_at           DateTime?            @db.Timestamp(0)
  created_at           DateTime?            @db.Timestamp(0)
  updated_at           DateTime?            @db.Timestamp(0)
  id                   String               @id @default(uuid()) @db.Uuid
  id_provider          String               @db.Uuid
  id_user              String?              @db.Uuid
  ctl_provider_storage ctl_provider_storage @relation(fields: [id_provider], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_storage_files_id_provider_foreign")
  mnt_user             mnt_user?            @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_storage_files_id_user_foreign")

  @@index([id_provider])
  @@index([id_user])
}

model mnt_user {
  user_name                 String                      @db.VarChar(150)
  password                  String                      @db.VarChar(150)
  last_access               DateTime                    @db.Timestamptz(0)
  is_validated              Boolean
  email_verified_at         DateTime?                   @db.Timestamp(0)
  created_at                DateTime?                   @db.Timestamp(0)
  updated_at                DateTime?                   @db.Timestamp(0)
  deleted_at                DateTime?                   @db.Timestamp(0)
  id                        String                      @id @default(uuid()) @db.Uuid
  id_people                 String                      @unique(map: "mnt_user_id_people_unique") @db.Uuid
  id_status                 String                      @db.Uuid
  login_attempts            Int                         @default(0)
  locked_until              DateTime?                   @db.Timestamp(6)
  mnt_session_refresh_token mnt_session_refresh_token[]
  mnt_storage_files         mnt_storage_files[]
  mnt_password_history      mnt_password_history[]
  mnt_people                mnt_people                  @relation(fields: [id_people], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_user_id_people_foreign")
  ctl_status                ctl_status                  @relation(fields: [id_status], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_user_id_status_foreign")
  mnt_user_rol              mnt_user_rol[]

  @@index([id_status])
  @@index([user_name])
  @@index([deleted_at])
}

model mnt_user_rol {
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
  id         String    @id @default(uuid()) @db.Uuid
  id_role    String    @db.Uuid
  id_user    String    @db.Uuid
  mnt_role   mnt_role  @relation(fields: [id_role], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_user_rol_id_role_foreign")
  mnt_user   mnt_user  @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_user_rol_id_user_foreign")

  @@unique([id_user, id_role], map: "mnt_user_rol_user_role_unique")
  @@index([id_user])
  @@index([id_role])
}

model people_country {
  created_at  DateTime?   @db.Timestamp(0)
  updated_at  DateTime?   @db.Timestamp(0)
  deleted_at  DateTime?   @db.Timestamp(0)
  id          String      @id @default(uuid()) @db.Uuid
  id_people   String      @db.Uuid
  id_country  String      @db.Uuid
  ctl_country ctl_country @relation(fields: [id_country], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "people_country_id_country_foreign")
  mnt_people  mnt_people  @relation(fields: [id_people], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "people_country_id_people_foreign")

  @@unique([id_people, id_country], map: "people_country_people_country_unique")
  @@index([id_people])
  @@index([id_country])
}

model rol_permissions {
  created_at      DateTime?       @db.Timestamp(0)
  updated_at      DateTime?       @db.Timestamp(0)
  deleted_at      DateTime?       @db.Timestamp(0)
  id              String          @id @default(uuid()) @db.Uuid
  id_role         String          @db.Uuid
  id_permission   String          @db.Uuid
  ctl_permissions ctl_permissions @relation(fields: [id_permission], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rol_permissions_id_permission_foreign")
  mnt_role        mnt_role        @relation(fields: [id_role], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "rol_permissions_id_role_foreign")

  @@unique([id_role, id_permission], map: "rol_permissions_role_permission_unique")
  @@index([id_role])
  @@index([id_permission])
}

model mnt_email_verification_tokens {
  token             String    @unique @db.VarChar(255)
  used_at           DateTime? @db.Timestamp(0)
  expires_at        DateTime  @db.Timestamp(0)
  created_at        DateTime? @default(now()) @db.Timestamp(0)
  id                String    @id @default(uuid()) @db.Uuid
  id_user           String    @db.Uuid
  // Prisma field renamed (typo); @map preserves the existing DB column so the
  // change is zero-downtime. A follow-up migration can ALTER COLUMN to drop
  // the @map once all environments deploy this.
  is_reset_password Boolean   @default(false) @map("is_resset_password") @db.Boolean

  @@index([id_user])
  @@index([token])
  @@index([id_user, is_reset_password, used_at])
}

model ctl_category_status {
  name        String       @unique(map: "ctl_category_status_name_idx") @db.VarChar(150)
  code        String       @unique(map: "ctl_category_status_code_idx") @db.VarChar(10)
  description String       @db.VarChar(150)
  active      Boolean
  id          String       @id(map: "ctl_category_status_pk") @default(uuid()) @db.Uuid
  ctl_status  ctl_status[]
}

model mnt_session_refresh_token {
  refresh_token_hashed String    @db.VarChar
  revoked_at           DateTime? @db.Timestamp(6)
  expired_at           DateTime  @db.Timestamp(6)
  created_at           DateTime  @default(now()) @db.Timestamp(6)
  last_used_at         DateTime? @db.Timestamp(6)
  id                   String    @id(map: "mnt_session_refresh_token_pk") @default(uuid()) @db.Uuid
  id_user              String    @db.Uuid
  device_name          String?   @db.VarChar(255)
  user_agent           String?   @db.Text
  ip_address           String?   @db.VarChar(45)
  mnt_user             mnt_user  @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "mnt_session_refresh_token_mnt_user_fk")

  @@index([id_user])
  @@index([id_user, revoked_at])
  @@index([expired_at])
}

model mnt_password_history {
  id            String   @id @default(uuid()) @db.Uuid
  id_user       String   @db.Uuid
  password_hash String   @db.VarChar(150)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  mnt_user      mnt_user @relation(fields: [id_user], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "mnt_password_history_id_user_fk")

  @@index([id_user])
  @@index([id_user, created_at])
}

model mnt_audit_log {
  id          String   @id @default(uuid()) @db.Uuid
  action      String   @db.VarChar(100)
  user_name   String?  @db.VarChar(255)
  user_id     String?  @db.Uuid
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(512)
  metadata    Json?
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.VarChar(255)
  created_at  DateTime @default(now()) @db.Timestamp(0)

  @@index([action])
  @@index([user_id])
  @@index([created_at])
  @@index([entity_type, entity_id])
}

model ctl_geographic_division {
  id                            String                       @id(map: "ctl_geographic_division_pk") @default(uuid()) @db.Uuid
  name                          String                       @db.VarChar(150)
  description                   String?                      @db.VarChar(200)
  id_parent                     String?                      @db.Uuid
  id_country                    String                       @db.Uuid
  id_type                       String                       @db.Uuid
  active                        Boolean                      @default(true)
  created_at                    DateTime                     @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?                    @db.Timestamp(6)
  deleted_at                    DateTime?                    @db.Timestamp(6)

  ctl_country                   ctl_country                  @relation(fields: [id_country], references: [id], onDelete: Cascade, map: "ctl_geographic_division_ctl_country_fk")
  ctl_geographic_division       ctl_geographic_division?     @relation("ctl_geographic_divisionToctl_geographic_division", fields: [id_parent], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ctl_geographic_division_ctl_geographic_division_fk")
  other_ctl_geographic_division ctl_geographic_division[]    @relation("ctl_geographic_divisionToctl_geographic_division")
  ctl_geographic_division_type  ctl_geographic_division_type @relation(fields: [id_type], references: [id], onDelete: Cascade, map: "ctl_geographic_division_ctl_geographic_division_type_fk")
  mnt_address                   mnt_address[]

  @@index([id_country])
  @@index([id_parent])
  @@index([id_type])

  @@index([id_country, id_parent])
  @@index([id_country, id_type])
  @@index([id_parent, id_country])

  @@unique([name, id_parent, id_country])
}

model ctl_geographic_division_type {
  id                      String                    @id(map: "ctl_geographic_division_type_pk") @default(uuid()) @db.Uuid
  id_country              String                    @db.Uuid
  name                    String                    @db.VarChar(150)
  level                   Int
  active                  Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  deleted_at              DateTime?                 @db.Timestamp(6)
  ctl_geographic_division ctl_geographic_division[]
  ctl_country             ctl_country               @relation(fields: [id_country], references: [id], onDelete: Cascade, map: "ctl_geographic_division_type_ctl_country_fk")

  @@unique([id_country, level], name: "ctl_geographic_division_type_country_level_unique")
  @@index([id_country])
}
