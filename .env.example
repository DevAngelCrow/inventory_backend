PORT=3000
DB_HOST=host.docker.internal
DB_USER=user
DB_PASSWORD=p4$$w0rd
DB_NAME=nest_db_template
DB_PORT=5432
DATABASE_URL="postgresql://user:p4$$w0rd@localhost:5432/nest_db_template?schema=public"
DB_PROVIDER="postgresql"

# Optional connection-pool tuning (defaults: max=10, idle=30s, conn=5s).
# Scale `max` per instance so total connections across replicas stays below
# Postgres `max_connections` (or use PgBouncer in front).
# DATABASE_POOL_MAX=10
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_CONN_TIMEOUT_MS=5000

NODE_ENV=development
SHOW_STACK_TRACE=false
# Storage backend: LOCAL writes to ./storage/, S3 uploads to an S3-compatible
# bucket. Multi-instance deployments MUST use S3 (or another remote backend)
# because LOCAL only persists on the writing node.
PROVIDER_STORAGE_CODE=LOCAL

# S3 backend — required only when PROVIDER_STORAGE_CODE=S3.
# S3_REGION=us-east-1
# S3_BUCKET=my-bucket
# S3_ENDPOINT=                  # custom endpoint for MinIO / R2 / B2
# S3_ACCESS_KEY_ID=             # omit to use IAM role / default credential chain
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=          # "true" for MinIO and other path-style providers
# S3_PUBLIC_BASE_URL=           # CDN/public URL; otherwise paths are stored as s3://bucket/key
# S3_KEY_PREFIX=                # optional prefix applied to every key (e.g. "profiles/")

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d

JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

EMAIL_HOST=gmail
EMAIL_FROM=NEST_APP@mail.com
EMAIL_PORT=587
EMAIL_USER=your email
EMAIL_PASSWORD=your password
EMAIL_SECRET=your secret

SONAR_TOKEN=your_sonar_token

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
# Must be at least 12 characters. Never commit a real value here.
REDIS_PASSWORD=replace_with_strong_random_value

CLIENT_URL=http://localhost:5174
# Optional: comma-separated list of additional allowed CORS origins
# CORS_ORIGINS=https://app.domain.com,https://admin.domain.com
CLIENT_VERIFY_EMAIL_ROUTE=/verify-email
CLIENT_FORGOTTEN_PASSWORD=/reset-forgotten-password

EMAIL_COLOR_PRIMARY='#059669'
EMAIL_COLOR_SURFACE='#e0e7ff'
EMAIL_COLOR_BACKGROUND_CARD='#eef2ff'
EMAIL_TEXT_MUTED='#a5b4fc'

# Swagger Basic Auth (required in non-development environments)
SWAGGER_USER=admin_docs
SWAGGER_PASSWORD=postTest
ENABLE_API_DOCS=false



# Account lockout — defaults: 5 attempts, 15-minute lockout window
# AUTH_MAX_LOGIN_ATTEMPTS=5
# AUTH_LOCKOUT_MINUTES=15

# Password history — how many previous passwords to block reuse of (default 5)
# PASSWORD_HISTORY_COUNT=5